# OpenAI API key — used by `make doc-search` / `make doc-search-all`
# to create embedding vectors for the docs search index.
# Also used by `scripts/docs-i18n.py` for docs translation.
OPENAI_API_KEY=sk-your-key-here

# Optional model override for docs translation script.
# Defaults to gpt-5.2 when unset.
OPENAI_TRANSLATION_MODEL=gpt-5.2
