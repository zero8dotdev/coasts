{
  "name": "coast-guard",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:coast-dev": "VITE_API_PORT=31416 vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "generate:types": "cd .. && cargo test -p coast-core export_bindings && cd coast-guard/src/types/generated && ls *.ts | sort | grep -v index.ts | sed 's/\\.ts$//' | awk '{print \"export type { \" $0 \" } from \\\"./\" $0 \"\\\";\"}'  > index.ts",
    "generate:docs": "node scripts/generate-docs.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "d3": "^7.9.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "eslint": "^10.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.0"
  }
}
